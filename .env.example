# ==========================================
# CRONOS API - Variables de Entorno (Ejemplo)
# ==========================================

# Configuración del Servidor
API_PORT=8080
API_ENV=development # development, testing, production

# CORS (usa * en local o una lista separada por comas en despliegue)
# Ejemplo producción: https://app.midominio.com,https://admin.midominio.com
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Configuración de Base de Datos (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=cronos_db_v1
DB_USER=
DB_PASSWORD=

# Firma para los JSON Web Tokens (Usa una cadena larga y aleatoria en producción)
JWT_SECRET=jeje_makanaki_la_realeza_cronos_api_2026_gaaa
